# Frontend config — most app config also lives in app.json -> expo.extra.
# When set, EXPO_PUBLIC_* vars are inlined at build time and override extra.

# Backend base URL. Use your machine's LAN IP on a physical device, e.g. http://192.168.1.5:4000/api
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# Firebase web config (Firebase console -> Project settings -> Your apps -> Web app)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth client IDs (Google Cloud console / Firebase Auth)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
